generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  passwordHash           String
  grade                  String?
  school                 String?
  avatarColour           String                  @default("#1976D2")
  streakCount            Int                     @default(0)
  lastActive             DateTime                @default(now())
  createdAt              DateTime                @default(now())
  emailVerified          Boolean                 @default(false)
  verifyToken            String?
  verifyTokenExp         DateTime?
  resetToken             String?
  resetTokenExp          DateTime?
  role                   String                  @default("student")
  referralCode           String                  @unique @default(uuid())
  referredBy             String?
  aiChatUsage            AiChatUsage[]
  bookmarks              Bookmark[]
  dailyChallengeAttempts DailyChallengeAttempt[]
  practiceTests          PracticeTest[]
  referralsMade          Referral[]              @relation("Referrer")
  referredThrough        Referral?               @relation("Referred")
  referralRewards        ReferralReward[]
  subscription           Subscription?
  badges                 UserBadge[]
  lessonProgress         UserLessonProgress[]
  points                 UserPoint[]

  @@index([email])
  @@index([createdAt])
  @@index([role])
  @@index([referralCode])
}

model Referral {
  id          String    @id @default(uuid())
  referrerId  String
  referredId  String    @unique
  status      String    @default("registered") // registered | paid
  createdAt   DateTime  @default(now())
  convertedAt DateTime? // when referred user upgraded to premium
  referrer    User      @relation("Referrer", fields: [referrerId], references: [id])
  referred    User      @relation("Referred", fields: [referredId], references: [id])

  @@index([referrerId])
  @@index([referredId])
  @@index([status])
}

model ReferralReward {
  id             String   @id @default(uuid())
  userId         String
  tier           String   // tier_5 | tier_10 | tier_30
  paidReferrals  Int
  rewardMonths   Int      // 1, 3, or 12
  claimedAt      DateTime @default(now())
  applied        Boolean  @default(false)
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Subscription {
  id               String   @id @default(uuid())
  userId           String   @unique
  plan             String
  status           String   @default("active")
  startedAt        DateTime @default(now())
  expiresAt        DateTime
  paymentReference String?
  amountUsd        Float
  user             User     @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([expiresAt])
}

model Topic {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  description    String?
  syllabusPoints Json?
  orderIndex     Int
  icon           String?
  tier           Int            @default(1)
  lessons        Lesson[]
  practiceTests  PracticeTest[]
  questions      Question[]
}

model Paper {
  id                String     @id @default(uuid())
  year              Int
  session           String
  paperNumber       Int
  title             String
  pdfUrl            String?
  difficultyOverall String     @default("medium")
  isFree            Boolean    @default(false)
  totalMarks        Int?
  questionCount     Int?
  createdAt         DateTime   @default(now())
  questions         Question[]

  @@index([isFree])
  @@index([title])
}

model Question {
  id               String           @id @default(uuid())
  paperId          String?
  questionNumber   Int
  questionText     String
  questionImageUrl String?
  marks            Int
  difficulty       String           @default("medium")
  topicId          String
  subtopic         String?
  solutionText     String?
  solutionSteps    Json?
  videoUrl         String?
  isFree           Boolean          @default(false)
  isDailyEligible  Boolean          @default(false)
  createdAt        DateTime         @default(now())
  correctAnswer    String?
  bookmarks        Bookmark[]
  dailyChallenges  DailyChallenge[]
  paper            Paper?           @relation(fields: [paperId], references: [id])
  topic            Topic            @relation(fields: [topicId], references: [id])

  @@index([topicId])
  @@index([paperId])
  @@index([isFree])
  @@index([isDailyEligible])
  @@index([difficulty])
}

model Lesson {
  id               String               @id @default(uuid())
  topicId          String
  title            String
  content          String
  orderIndex       Int
  isFree           Boolean              @default(false)
  estimatedMinutes Int                  @default(10)
  publishedAt      DateTime             @default(now())
  videoUrl         String?
  geogebraUrl      String?
  imageUrl         String?
  topic            Topic                @relation(fields: [topicId], references: [id])
  progress         UserLessonProgress[]

  @@index([topicId])
  @@index([orderIndex])
}

model PracticeTest {
  id               String   @id @default(uuid())
  userId           String
  topicId          String?
  difficulty       String   @default("mixed")
  questionCount    Int
  scorePercentage  Float
  timeTakenSeconds Int?
  completedAt      DateTime @default(now())
  questionsData    Json?
  topic            Topic?   @relation(fields: [topicId], references: [id])
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([topicId])
  @@index([completedAt])
  @@index([scorePercentage])
}

model DailyChallenge {
  id              String                  @id @default(uuid())
  questionId      String
  date            DateTime                @unique
  totalAttempts   Int                     @default(0)
  correctAttempts Int                     @default(0)
  question        Question                @relation(fields: [questionId], references: [id])
  attempts        DailyChallengeAttempt[]

  @@index([date])
}

model DailyChallengeAttempt {
  id               String         @id @default(uuid())
  userId           String
  dailyChallengeId String
  userAnswer       String?
  isCorrect        Boolean        @default(false)
  attemptedAt      DateTime       @default(now())
  pointsAwarded    Int            @default(0)
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([dailyChallengeId])
  @@index([attemptedAt])
}

model UserPoint {
  id        String   @id @default(uuid())
  userId    String
  points    Int
  source    String
  sourceId  String?
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([awardedAt])
  @@index([source])
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeSlug String
  awardedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([badgeSlug])
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  note       String?
  createdAt  DateTime @default(now())
  question   Question @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([questionId])
}

model UserLessonProgress {
  id          String   @id @default(uuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lessonId])
}

model AiChatUsage {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime
  messageCount Int      @default(0)
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
}

model WhatsAppPost {
  id          String   @id @default(uuid())
  content     String
  contentType String   // question, tip, fact, motivation, leaderboard
  postedAt    DateTime @default(now())
  posted      Boolean  @default(false)
  createdAt   DateTime @default(now())
}